@model VehicleInspectionSystem.Web.Models.DashboardDto

@{
    ViewData["Title"] = "Аналітика";

    var appointmentStats = ViewBag.AppointmentStats as VehicleInspectionSystem.Web.Models.AppointmentStatisticsDto;
    
    var activeReminders =
    ViewBag.ActiveReminders as List<VehicleInspectionSystem.Web.Models.ReminderDto>
    ?? new List<VehicleInspectionSystem.Web.Models.ReminderDto>();

    var readReminders =
        ViewBag.ReadReminders as List<VehicleInspectionSystem.Web.Models.ReminderDto>
        ?? new List<VehicleInspectionSystem.Web.Models.ReminderDto>();

    var vehicleLabels = Model?.ByVehicleType.Select(x => x.Name).ToList() ?? new List<string>();
    var vehicleData = Model?.ByVehicleType.Select(x => x.Count).ToList() ?? new List<int>();

    var categoryLabels = Model?.ByCategory.Select(x => x.Name).ToList() ?? new List<string>();
    var categoryData = Model?.ByCategory.Select(x => x.Count).ToList() ?? new List<int>();

    var statusLabels = Model?.ByStatus.Select(x => x.Name).ToList() ?? new List<string>();
    var statusData = Model?.ByStatus.Select(x => x.Count).ToList() ?? new List<int>();

    var dateLabels = Model?.ByDate.Select(x => x.Date).ToList() ?? new List<string>();
    var dateData = Model?.ByDate.Select(x => x.Count).ToList() ?? new List<int>();
}

<div class="container-fluid px-4 mt-4 dashboard-page">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Аналітична панель</h2>

        <div class="d-flex gap-2 align-items-end">

            <form method="get"
                  asp-controller="Dashboard"
                  asp-action="Index"
                  class="d-flex gap-2 align-items-end">

                <div>
                    <label class="form-label mb-1">Дата від</label>
                    <input type="date"
                           name="dateFrom"
                           value="@Model?.DateFrom"
                           class="form-control" />
                </div>

                <div>
                    <label class="form-label mb-1">Дата до</label>
                    <input type="date"
                           name="dateTo"
                           value="@Model?.DateTo"
                           class="form-control" />
                </div>

                <button type="submit" class="btn btn-primary">
                    Оновити
                </button>

            </form>

            <form method="post"
                  asp-controller="Dashboard"
                  asp-action="ExportPdf">

                <input type="hidden"
                       name="dateFrom"
                       value="@Model?.DateFrom" />

                <input type="hidden"
                       name="dateTo"
                       value="@Model?.DateTo" />

                <button type="submit"
                        class="btn btn-outline-danger">
                    📄 PDF-звіт
                </button>

            </form>

        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-xl-2 col-md-4">
            <div class="kpi-card bg-primary text-white dashboard-card" data-bs-toggle="modal" data-bs-target="#totalModal">
                <span>Проведено ТО</span>
                <h2>@Model?.TotalInspections</h2>
                <small>Натисніть для деталізації</small>
            </div>
        </div>

        <div class="col-xl-2 col-md-4">
            <div class="kpi-card bg-danger text-white">
                <span>Актів невідповідності</span>
                <h2>@Model?.NonComplianceActs</h2>
            </div>
        </div>

        <div class="col-xl-2 col-md-4">
            <div class="kpi-card bg-warning text-dark">
                <span>Міжнародних ТО</span>
                <h2>@Model?.InternationalInspections</h2>
            </div>
        </div>

        <div class="col-xl-2 col-md-4">
            <div class="kpi-card bg-light">
                <span>Кількість клієнтів</span>
                <h2>@Model?.ClientsCount</h2>
            </div>
        </div>

        <div class="col-xl-2 col-md-4">
            <div class="kpi-card bg-light">
                <span>Нових клієнтів</span>
                <h2>@Model?.NewClientsCount</h2>
            </div>
        </div>

        <div class="col-xl-2 col-md-4">
            <div class="kpi-card bg-light">
                <span>Анульованих документів</span>
                <h2>@Model?.CanceledCount</h2>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="kpi-card bg-info text-white">
                <span>Усього заявок</span>
                <h2>@(appointmentStats?.Total ?? 0)</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="kpi-card bg-warning text-dark">
                <span>Нові заявки</span>
                <h2>@(appointmentStats?.NewCount ?? 0)</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="kpi-card bg-success text-white">
                <span>Підтверджені</span>
                <h2>@(appointmentStats?.ConfirmedCount ?? 0)</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="kpi-card bg-primary text-white">
                <span>Виконані</span>
                <h2>@(appointmentStats?.CompletedCount ?? 0)</h2>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="analytics-card">
                <div class="card-header fw-semibold">Динаміка проведених ТО</div>
                <div class="card-body">
                    <canvas id="dateChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="analytics-card">
                <div class="card-header fw-semibold">Розподіл за типами ТЗ</div>
                <div class="card-body">
                    <canvas id="vehicleChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="analytics-card">
                <div class="card-header fw-semibold">Розподіл за категоріями</div>
                <div class="card-body">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="analytics-card">
                <div class="card-header fw-semibold">Статистика за статусами</div>
                <div class="card-body">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="reminder-section mb-5">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h5 class="fw-bold mb-1">⚠ Нагадування про закінчення ОТК</h5>
                <small>Активні та прочитані повідомлення щодо завершення строку дії технічного огляду.</small>
            </div>

            <div class="d-flex gap-2">
                <span class="badge bg-warning text-dark">
                    Активні: @activeReminders.Count
                </span>

                <span class="badge bg-secondary">
                    Прочитані: @readReminders.Count
                </span>
            </div>
        </div>

        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <button class="nav-link active"
                        data-bs-toggle="tab"
                        data-bs-target="#active-reminders"
                        type="button">
                    Активні
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link"
                        data-bs-toggle="tab"
                        data-bs-target="#read-reminders"
                        type="button">
                    Прочитані
                </button>
            </li>
        </ul>

        <div class="tab-content">

            <div class="tab-pane fade show active" id="active-reminders">
                <div class="reminder-table-wrapper">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Держ. номер</th>
                                <th>ТЗ</th>
                                <th>Власник</th>
                                <th>Телефон</th>
                                <th>Дата закінчення</th>
                                <th>Залишилось</th>
                                <th>Тип</th>
                                <th style="width:260px">Дії</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in activeReminders)
                            {
                                var phone = string.IsNullOrWhiteSpace(item.OwnerPhone) ? "Не вказано" : item.OwnerPhone;
                                var daysText = item.DaysLeft == 0 ? "Сьогодні" : $"{item.DaysLeft} днів";
                                var statusClass = item.DaysLeft == 0 ? "bg-danger" : "bg-warning text-dark";

                                <tr>
                                    <td class="fw-bold">@item.PlateNumber</td>
                                    <td>@item.Brand @item.Model</td>
                                    <td>@item.Owner</td>
                                    <td>
                                        @if (phone != "Не вказано")
                                        {
                                            <a href="tel:@phone">@phone</a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Не вказано</span>
                                        }
                                    </td>
                                    <td>@item.NextInspectionDate?.ToString("dd.MM.yyyy")</td>
                                    <td>@daysText</td>
                                    <td>
                                        <span class="badge @statusClass">
                                            @item.ReminderType
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1 flex-wrap">
                                            <button type="button"
                                                    class="btn btn-outline-primary btn-sm"
                                                    onclick="showReminderDetails('@item.PlateNumber', '@item.Owner', '@phone', '@item.NextInspectionDate?.ToString("dd.MM.yyyy")', '@item.DaysLeft')">
                                                Переглянути
                                            </button>

                                            <form asp-controller="Dashboard"
                                                  asp-action="MarkReminderAsRead"
                                                  method="post">
                                                <input type="hidden" name="id" value="@item.Id" />

                                                <button type="submit"
                                                        class="btn btn-outline-success btn-sm">
                                                    Прочитано
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="tab-pane fade" id="read-reminders">
                <div class="reminder-table-wrapper">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Держ. номер</th>
                                <th>ТЗ</th>
                                <th>Власник</th>
                                <th>Телефон</th>
                                <th>Дата закінчення</th>
                                <th>Прочитано</th>
                                <th>Тип</th>
                                <th style="width:140px">Дії</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in readReminders)
                            {
                                var phone = string.IsNullOrWhiteSpace(item.OwnerPhone) ? "Не вказано" : item.OwnerPhone;

                                <tr>
                                    <td class="fw-bold">@item.PlateNumber</td>
                                    <td>@item.Brand @item.Model</td>
                                    <td>@item.Owner</td>
                                    <td>
                                        @if (phone != "Не вказано")
                                        {
                                            <a href="tel:@phone">@phone</a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Не вказано</span>
                                        }
                                    </td>
                                    <td>@item.NextInspectionDate?.ToString("dd.MM.yyyy")</td>
                                    <td>@item.ReadAt?.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        <span class="badge bg-secondary">
                                            @item.ReminderType
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1 flex-wrap">
                                            <button type="button"
                                                    class="btn btn-outline-primary btn-sm"
                                                    onclick="showReminderDetails('@item.PlateNumber', '@item.Owner', '@phone', '@item.NextInspectionDate?.ToString("dd.MM.yyyy")', '@item.DaysLeft')">
                                                Переглянути
                                            </button>

                                            <form asp-controller="Dashboard"
                                                  asp-action="MarkReminderAsUnread"
                                                  method="post">
                                                <input type="hidden" name="id" value="@item.Id" />

                                                <button type="submit"
                                                        class="btn btn-outline-warning btn-sm">
                                                    Повернути в активні
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>

</div>

<div class="modal fade" id="totalModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Деталізація проведених ТО</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <h6>За типами ТЗ</h6>
                <ul>
                    @foreach (var item in Model?.ByVehicleType ?? new())
                    {
                        <li>@item.Name — @item.Count</li>
                    }
                </ul>

                <h6 class="mt-3">За категоріями</h6>
                <ul>
                    @foreach (var item in Model?.ByCategory ?? new())
                    {
                        <li>@item.Name — @item.Count</li>
                    }
                </ul>

                <h6 class="mt-3">За статусами</h6>
                <ul>
                    @foreach (var item in Model?.ByStatus ?? new())
                    {
                        <li>@item.Name — @item.Count</li>
                    }
                </ul>

                <h6 class="mt-3">За типом власника</h6>
                <ul>
                    @foreach (var item in Model?.ByOwnerType ?? new())
                    {
                        <li>@item.Name — @item.Count</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="reminderDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Деталі нагадування</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="mb-2"><strong>Держ. номер:</strong> <span id="detailPlate">-</span></div>
                <div class="mb-2"><strong>Власник:</strong> <span id="detailOwner">-</span></div>
                <div class="mb-2"><strong>Телефон:</strong> <span id="detailPhone">-</span></div>
                <div class="mb-2"><strong>Дата закінчення ОТК:</strong> <span id="detailDate">-</span></div>
                <div class="mb-3"><strong>Залишилось:</strong> <span id="detailDays">-</span></div>

                <label class="form-label fw-semibold">Повідомлення для клієнта</label>
                <textarea id="clientMessage" class="form-control mb-3" rows="6" readonly></textarea>

                <button type="button" class="btn btn-outline-primary" onclick="copyClientMessage()">
                    Скопіювати повідомлення
                </button>

            </div>

        </div>
    </div>
</div>

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
                const dateLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dateLabels));
                const dateData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dateData));

                const vehicleLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(vehicleLabels));
                const vehicleData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(vehicleData));

                const categoryLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(categoryLabels));
                const categoryData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(categoryData));

                const statusLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(statusLabels));
                const statusData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(statusData));

                new Chart(document.getElementById('dateChart'), {
                    type: 'line',
                    data: {
                        labels: dateLabels,
                        datasets: [{
                            label: 'Кількість ТО',
                            data: dateData,
                            tension: 0.3
                        }]
                    }
                });

                new Chart(document.getElementById('vehicleChart'), {
                    type: 'doughnut',
                    data: {
                        labels: vehicleLabels,
                        datasets: [{
                            data: vehicleData
                        }]
                    }
                });

                new Chart(document.getElementById('categoryChart'), {
                    type: 'pie',
                    data: {
                        labels: categoryLabels,
                        datasets: [{
                            data: categoryData
                        }]
                    }
                });

                new Chart(document.getElementById('statusChart'), {
                    type: 'doughnut',
                    data: {
                        labels: statusLabels,
                        datasets: [{
                            data: statusData
                        }]
                    }
                });

                        function showReminderDetails(plate, owner, phone, date, daysLeft) {
            const days = parseInt(daysLeft);
            const daysText = days === 0 ? "сьогодні" : `${days} днів`;

            document.getElementById("detailPlate").innerText = plate;
            document.getElementById("detailOwner").innerText = owner;
            document.getElementById("detailPhone").innerText = phone;
            document.getElementById("detailDate").innerText = date;
            document.getElementById("detailDays").innerText = daysText;

            const message =
        `Добрий день! Повідомляємо, що термін дії технічного огляду для ТЗ з державним номером ${plate} закінчується ${days === 0 ? "сьогодні" : `через ${days} днів`} (${date}).

        Просимо записатися на новий технічний огляд у зручний для вас час. Дякуємо!`;

            document.getElementById("clientMessage").value = message;

            const modal = new bootstrap.Modal(document.getElementById("reminderDetailsModal"));
            modal.show();
        }

                function copyClientMessage() {
                    const text = document.getElementById("clientMessage");
                    text.select();
                    text.setSelectionRange(0, 99999);
                    navigator.clipboard.writeText(text.value);
                }
    </script>
}