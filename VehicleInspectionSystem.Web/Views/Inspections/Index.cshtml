@model List<VehicleInspectionSystem.Web.Models.InspectionDto>

<div class="container-fluid px-5 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>Журнал технічних оглядів</h2>

        <div class="d-flex gap-2">

            @if (User.IsInRole("Admin") || User.IsInRole("Operator") || User.IsInRole("Expert"))
            {
                <a class="btn btn-primary fw-semibold"
                   asp-controller="Inspections"
                   asp-action="Create">
                    Додати запис
                </a>
            }

            @if (User.IsInRole("Admin") || User.IsInRole("Operator"))
            {
                <a asp-controller="Import"
                   asp-action="Index"
                   class="btn btn-success">
                    Імпорт Excel
                </a>
            }

        </div>

    </div>
    <form method="get"
          asp-controller="Inspections"
          asp-action="Index"
          class="mb-4">

        <div class="row g-3 align-items-end">

            <div class="col-md-2">
                <label class="form-label fw-semibold">Держ. номер</label>
                <input class="form-control" type="text" name="plate" value="@ViewBag.Plate" />
            </div>

            <div class="col-md-2">
                <label class="form-label fw-semibold">VIN</label>
                <input class="form-control" type="text" name="vin" value="@ViewBag.Vin" />
            </div>

            <div class="col-md-2">
                <label class="form-label fw-semibold">Власник</label>
                <input class="form-control" type="text" name="owner" value="@ViewBag.Owner" />
            </div>

            <div class="col-md-2">
                <label class="form-label fw-semibold">Марка</label>
                <input class="form-control" type="text" name="brand" value="@ViewBag.Brand" />
            </div>

            <div class="col-md-2">
                <label class="form-label fw-semibold">Модель</label>
                <input class="form-control" type="text" name="model" value="@ViewBag.Model" />
            </div>

            <div class="col-md-2">
                <label class="form-label fw-semibold">Пошук від</label>
                <input class="form-control" type="date" name="dateFrom" value="@ViewBag.DateFrom" />
            </div>

            <div class="col-md-2">
                <label class="form-label fw-semibold">Пошук до</label>
                <input class="form-control" type="date" name="dateTo" value="@ViewBag.DateTo" />
            </div>

            <div class="col-md-2">
                <label class="form-label fw-semibold">Сортувати за</label>
                <select class="form-select" name="sortBy">
                    <option value="">Оберіть</option>
                    <option value="date">Датою</option>
                    <option value="brand">Маркою</option>
                    <option value="model">Моделлю</option>
                    <option value="owner">Власником</option>
                    <option value="plate">Номером</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label fw-semibold">Напрямок</label>
                <select class="form-select" name="sortDirection">
                    <option value="asc">За зростанням</option>
                    <option value="desc">За спаданням</option>
                </select>
            </div>

            <div class="col-md-2 d-grid">
                <button class="btn btn-success fw-semibold" type="submit">
                    Застосувати
                </button>
            </div>

            <div class="col-md-2 d-grid">
                <a class="btn btn-secondary fw-semibold"
                   asp-controller="Inspections"
                   asp-action="Index">
                    Очистити
                </a>
            </div>

        </div>
    </form>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover table-bordered align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width:60px">№</th>
                    <th>Тип ТЗ</th>
                    <th>Марка</th>
                    <th>Модель</th>
                    <th style="width:90px">Категорія</th>
                    <th>Держ. номер</th>
                    <th style="width:120px">Дата</th>
                    <th>VIN</th>
                    <th>Власник</th>
                    <th style="width:120px">Дії</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.VehicleType</td>
                        <td>@item.Brand</td>
                        <td>@item.Model</td>
                        <td>@item.Category</td>
                        <td>@item.PlateNumber</td>
                        <td>@item.SignDate.ToString("dd.MM.yyyy")</td>
                        <td class="small">@item.VIN</td>
                        <td>@item.Owner</td>
                        <td>
                            <div class="d-flex gap-1">

                                <a asp-controller="Inspections"
                                   asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-primary btn-sm">
                                    Деталі
                                </a>

                                @if (User.IsInRole("Admin") || User.IsInRole("Expert"))
                                {
                                    <a asp-controller="Inspections"
                                       asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-outline-warning btn-sm">
                                        Редагувати
                                    </a>
                                }

                                @if (User.IsInRole("Admin"))
                                {
                                    <form asp-controller="Inspections"
                                          asp-action="Delete"
                                          asp-route-id="@item.Id"
                                          method="post"
                                          onsubmit="return confirm('Ви дійсно хочете видалити цей запис?');">

                                        <button type="submit"
                                                class="btn btn-outline-danger btn-sm">
                                            Видалити
                                        </button>
                                    </form>
                                }

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>