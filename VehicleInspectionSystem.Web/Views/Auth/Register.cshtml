@model VehicleInspectionSystem.Web.Models.RegisterViewModel

<div class="container mt-5" style="max-width: 450px;">
    <div class="card shadow-sm">
        <div class="card-body p-4">

            <h3 class="mb-4 text-center">Реєстрація</h3>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            <form asp-controller="Auth" asp-action="Register" method="post">

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" type="email" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Пароль</label>
                    <input asp-for="Password" class="form-control" type="password" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Повторіть пароль</label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" required />
                </div>

                <button type="submit" class="btn btn-success w-100">
                    Зареєструватися
                </button>

                <div class="text-center mt-3">
                    <span>Вже маєте акаунт?</span>
                    <a asp-controller="Auth"
                       asp-action="Login">
                        Увійти
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>